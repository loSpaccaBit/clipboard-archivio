    "Paste with ⌘V in the target app, then press Next for the following clip.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste with ⌘V in the target app, then press Next for the following clip."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla con ⌘V nell'app di destinazione, poi premi Prossimo per l'appunto successivo."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit ⌘V in der Ziel-App einfügen, dann Weiter für den nächsten Eintrag drücken."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez avec ⌘V dans l'app cible, puis appuyez sur Suivant pour l'élément suivant."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega con ⌘V en la app de destino y pulsa Siguiente para el siguiente elemento."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole com ⌘V no app de destino e pressione Próximo para o item seguinte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "対象アプリで⌘Vで貼り付け、次のクリップは「次へ」を押してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在目标 App 中用 ⌘V 粘贴，然后按“下一个”处理下一项。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "대상 앱에서 ⌘V로 붙여넣은 후 다음 클립은 '다음'을 누르세요."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Plak met ⌘V in de doel-app en druk op Volgende voor het volgende item."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wklej za pomocą ⌘V w aplikacji docelowej, następnie naciśnij Dalej dla kolejnego elementu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставьте с ⌘V в целевом приложении, затем нажмите «Далее» для следующего элемента."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصق بـ ⌘V في التطبيق المستهدف، ثم اضغط التالي للعنصر التالي."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hedef uygulamada ⌘V ile yapıştırın, sonraki öğe için Sonraki'ye basın."
          }
        }
      }
    },
