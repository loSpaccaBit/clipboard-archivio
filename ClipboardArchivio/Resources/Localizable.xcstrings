    "Choose the language for Appunti Archivio. Restart the panel to apply in some views.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the language for Appunti Archivio. Restart the panel to apply in some views."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli la lingua per Appunti Archivio. Riavvia il pannello per applicare in alcune viste."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie die Sprache für Clipboard Archive. Starten Sie das Panel neu, damit die Änderung in einigen Ansichten wirksam wird."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez la langue pour Clipboard Archive. Redémarrez le panneau pour l'appliquer dans certaines vues."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el idioma para Clipboard Archive. Reinicia el panel para aplicarlo en algunas vistas."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o idioma do Clipboard Archive. Reinicie o painel para aplicar em algumas visualizações."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard Archiveの言語を選択してください。一部の表示にはパネルの再起動が必要です。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 Clipboard Archive 的语言。部分视图需要重启面板后生效。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard Archive의 언어를 선택하세요. 일부 보기에는 패널을 다시 시작해야 적용됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies de taal voor Clipboard Archive. Start het paneel opnieuw om dit in sommige weergaven toe te passen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz język dla Clipboard Archive. Uruchom ponownie panel, aby zastosować w niektórych widokach."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите язык для Clipboard Archive. Перезапустите панель, чтобы применить в некоторых представлениях."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر لغة Clipboard Archive. أعد تشغيل اللوحة لتطبيقها في بعض العروض."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Clipboard Archive için dili seçin. Bazı görünümlerde uygulamak için paneli yeniden başlatın."
          }
        }
      }
