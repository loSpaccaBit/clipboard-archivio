    "Older items are removed automatically. Pinned and vault items are always excluded.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Older items are removed automatically. Pinned and vault items are always excluded."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli elementi più vecchi vengono eliminati automaticamente. Fissati e vault sono sempre esclusi."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ältere Einträge werden automatisch entfernt. Angeheftete und Tresor-Einträge sind immer ausgeschlossen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les éléments plus anciens sont supprimés automatiquement. Les épinglés et le coffre sont toujours exclus."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los elementos antiguos se eliminan automáticamente. Los fijados y de la bóveda siempre quedan excluidos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Itens mais antigos são removidos automaticamente. Fixados e do cofre são sempre excluídos."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "古い項目は自動的に削除されます。ピン留めとVaultの項目は常に除外されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较早的项目会自动移除。固定项和保险库项目始终除外。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오래된 항목은 자동으로 제거됩니다. 고정 및 보관함 항목은 항상 제외됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oudere items worden automatisch verwijderd. Vastgezette en kluisitems zijn altijd uitgesloten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Starsze elementy są usuwane automatycznie. Przypięte i elementy sejfu są zawsze wykluczone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Старые элементы удаляются автоматически. Закреплённые и элементы хранилища всегда исключены."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُزال العناصر الأقدم تلقائيًا. العناصر المثبتة وعناصر الخزنة مستثناة دائمًا."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eski öğeler otomatik olarak kaldırılır. Sabitlenen ve kasa öğeleri her zaman hariç tutulur."
          }
        }
      }
    },
