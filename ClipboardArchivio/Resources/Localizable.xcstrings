    "Idle target: CPU < 1%, RAM < 100 MB. Clipboard polling is adaptive: slower in background, stopped during privacy pause.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Idle target: CPU < 1%, RAM < 100 MB. Clipboard polling is adaptive: slower in background, stopped during privacy pause."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Obiettivo a riposo: CPU < 1%, RAM < 100 MB. Il polling degli appunti è adattivo: più lento in background, fermo in pausa privacy."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leerlaufziel: CPU < 1 %, RAM < 100 MB. Die Zwischenablage-Abfrage ist adaptiv: im Hintergrund langsamer, bei Datenschutzpause gestoppt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Objectif au repos : CPU < 1 %, RAM < 100 Mo. L'interrogation du presse-papiers est adaptative : plus lente en arrière-plan, arrêtée pendant la pause confidentialité."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Objetivo en reposo: CPU < 1 %, RAM < 100 MB. La consulta del portapapeles es adaptativa: más lenta en segundo plano, detenida durante la pausa de privacidad."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Meta em repouso: CPU < 1%, RAM < 100 MB. A consulta da área de transferência é adaptativa: mais lenta em segundo plano, interrompida durante a pausa de privacidade."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アイドル時の目標: CPU < 1%、RAM < 100 MB。クリップボードの監視は適応型で、バックグラウンドでは低速、プライバシー一時停止中は停止します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "空闲目标：CPU < 1%，RAM < 100 MB。剪贴板轮询为自适应：后台更慢，隐私暂停期间停止。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "유휴 목표: CPU < 1%, RAM < 100MB. 클립보드 폴링은 적응형으로 백그라운드에서 느리고, 개인정보 일시 중지 중에는 중단됩니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Idle-doel: CPU < 1%, RAM < 100 MB. Klembordpolling is adaptief: langzamer op de achtergrond, gestopt tijdens privacypauze."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel w stanie spoczynku: CPU < 1%, RAM < 100 MB. Odpytywanie schowka jest adaptacyjne: wolniejsze w tle, zatrzymane podczas pauzy prywatności."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цель в простое: CPU < 1%, RAM < 100 МБ. Опрос буфера адаптивный: медленнее в фоне, остановлен при паузе конфиденциальности."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الهدف في الخمول: CPU < 1%، RAM < 100 ميجابايت. مراقبة الحافظة تكيفية: أبطأ في الخلفية، متوقفة أثناء إيقاف الخصوصية."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boşta hedef: CPU < 1%, RAM < 100 MB. Pano yoklama uyarlanabilir: arka planda daha yavaş, gizlilik duraklatmasında durur."
          }
        }
      }
    },
